<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SwiftCare123P.BookingPage"
             Title="Book a Caregiver"
             BackgroundColor="#f4fbfc"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!-- Top Bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="16,16" BackgroundColor="White" ColumnSpacing="10">
            <Button Grid.Column="0" Text="&#8592;" FontSize="20" BackgroundColor="Transparent" TextColor="#062035"
                    Padding="0" WidthRequest="36" Clicked="OnBackClicked"/>
            <Label Grid.Column="1"
                   Text="Book a Caregiver"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#062035"
                   VerticalTextAlignment="Center"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" Padding="16">
            <VerticalStackLayout Spacing="16">

                <!-- Caregiver Summary -->
                <Border StrokeShape="RoundRectangle(14)" Padding="16" BackgroundColor="#0a2a4a">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Label Grid.Column="0" Text="&#128100;" FontSize="40" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label x:Name="lblCaregiverName" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                            <Label x:Name="lblCaregiverRate" FontSize="13" TextColor="#b0d4e3"/>
                            <Label x:Name="lblCaregiverRating" FontSize="12" TextColor="#ffd54f"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Service -->
                <Border StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Service" FontSize="12" FontAttributes="Bold" TextColor="#1a4a62"/>
                        <Picker x:Name="pckService"
                                Title="Select a service"
                                ItemDisplayBinding="{Binding ServiceName}"
                                BackgroundColor="#f4fbfc"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Availability Calendar -->
                <Border StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Choose a Date" FontSize="16" FontAttributes="Bold" TextColor="#062035"/>
                        <Label x:Name="lblAvailabilityHint" FontSize="12" TextColor="#4a7a92"/>

                        <Label x:Name="lblNoAvailability"
                               Text="This caregiver hasn't set their weekly availability yet. Please contact them directly to arrange a booking."
                               FontSize="12"
                               TextColor="#e53935"
                               IsVisible="False"/>

                        <Grid x:Name="gridCalendarHeader"
                              ColumnDefinitions="*,*,*,*,*,*,*"
                              IsVisible="False">
                            <Label Grid.Column="0" Text="Mon" FontSize="11" FontAttributes="Bold" TextColor="#4a7a92" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="1" Text="Tue" FontSize="11" FontAttributes="Bold" TextColor="#4a7a92" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="2" Text="Wed" FontSize="11" FontAttributes="Bold" TextColor="#4a7a92" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="3" Text="Thu" FontSize="11" FontAttributes="Bold" TextColor="#4a7a92" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="4" Text="Fri" FontSize="11" FontAttributes="Bold" TextColor="#4a7a92" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="5" Text="Sat" FontSize="11" FontAttributes="Bold" TextColor="#4a7a92" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="6" Text="Sun" FontSize="11" FontAttributes="Bold" TextColor="#4a7a92" HorizontalTextAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="gridCalendarNav" ColumnDefinitions="Auto,*,Auto" IsVisible="False">
                            <Button Grid.Column="0" x:Name="btnPrevMonth" Text="&#8249;" Clicked="OnPrevMonthClicked"
                                    BackgroundColor="#e8f4f8" TextColor="#062035" WidthRequest="40" CornerRadius="8"/>
                            <Label Grid.Column="1" x:Name="lblCalendarMonth" FontSize="14" FontAttributes="Bold"
                                   TextColor="#062035" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                            <Button Grid.Column="2" x:Name="btnNextMonth" Text="&#8250;" Clicked="OnNextMonthClicked"
                                    BackgroundColor="#e8f4f8" TextColor="#062035" WidthRequest="40" CornerRadius="8"/>
                        </Grid>

                        <Grid x:Name="gridCalendarDays" ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="4" RowSpacing="4"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Already Booked Slots -->
                <Border x:Name="borderBookedSlots" StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#fdecea" Padding="16" IsVisible="False" BackgroundColor="#fff8f7">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Already Booked on This Date" FontSize="13" FontAttributes="Bold" TextColor="#b71c1c"/>
                        <Label x:Name="lblBookedSlots" FontSize="12" TextColor="#e53935"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Time -->
                <Border StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Time" FontSize="16" FontAttributes="Bold" TextColor="#062035"/>
                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Start Time" FontSize="12" FontAttributes="Bold" TextColor="#1a4a62"/>
                                <TimePicker x:Name="tpStartTime" BackgroundColor="#f4fbfc"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="to" VerticalOptions="Center" FontSize="12" TextColor="#4a7a92"/>
                            <VerticalStackLayout Grid.Column="2" Spacing="6">
                                <Label Text="End Time" FontSize="12" FontAttributes="Bold" TextColor="#1a4a62"/>
                                <TimePicker x:Name="tpEndTime" BackgroundColor="#f4fbfc"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Booking Summary -->
                <Border StrokeShape="RoundRectangle(14)" Padding="16" BackgroundColor="#0a2a4a">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Booking Summary" FontSize="14" FontAttributes="Bold" TextColor="White"/>
                        <BoxView HeightRequest="1" BackgroundColor="#1a4a62"/>

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                            <Label Grid.Row="0" Grid.Column="0" Text="Date" FontSize="12" TextColor="#b0d4e3"/>
                            <Label Grid.Row="0" Grid.Column="1" x:Name="lblSummaryDate" Text="Not selected" FontSize="12" TextColor="White" HorizontalTextAlignment="End"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Time" FontSize="12" TextColor="#b0d4e3"/>
                            <Label Grid.Row="1" Grid.Column="1" x:Name="lblSummaryTime" Text="—" FontSize="12" TextColor="White" HorizontalTextAlignment="End"/>

                            <Label Grid.Row="2" Grid.Column="0" Text="Duration" FontSize="12" TextColor="#b0d4e3"/>
                            <Label Grid.Row="2" Grid.Column="1" x:Name="lblSummaryDuration" Text="—" FontSize="12" TextColor="White" HorizontalTextAlignment="End"/>

                            <Label Grid.Row="3" Grid.Column="0" Text="Rate" FontSize="12" TextColor="#b0d4e3"/>
                            <Label Grid.Row="3" Grid.Column="1" x:Name="lblSummaryRate" Text="—" FontSize="12" TextColor="White" HorizontalTextAlignment="End"/>

                            <Label Grid.Row="4" Grid.Column="0" Text="Booking Fee" FontSize="12" TextColor="#b0d4e3"/>
                            <Label Grid.Row="4" Grid.Column="1" x:Name="lblSummaryFee" Text="—" FontSize="12" TextColor="White" HorizontalTextAlignment="End"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#1a4a62"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Total" FontSize="15" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            <Label Grid.Column="1" x:Name="lblSummaryTotal" Text="&#8369;0.00" FontSize="20" FontAttributes="Bold" TextColor="#ffd54f" HorizontalTextAlignment="End"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="lblError"
                       TextColor="#e53935"
                       FontSize="13"
                       IsVisible="False"/>

                <Button Text="Confirm Booking"
                        Clicked="OnConfirmBookingClicked"
                        BackgroundColor="#006064"
                        TextColor="White"
                        CornerRadius="10"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
