<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SwiftCare123P.CaregiverDashboard"
             Title="Caregiver Dashboard"
             BackgroundColor="#f4fbfc"
             NavigationPage.HasNavigationBar="False">
    
    <Grid RowDefinitions="Auto,Auto,*" Padding="0">

        <!-- Top Bar -->
        <Grid Grid.Row="0" RowDefinitions="Auto" ColumnDefinitions="Auto,*,Auto" Padding="16,16" BackgroundColor="White" ColumnSpacing="10">
            <Button Grid.Column="0" Text="←" FontSize="20" BackgroundColor="Transparent" TextColor="#062035"
            Padding="0" WidthRequest="36" Clicked="OnBackClicked"/>
            <Label Grid.Column="1" 
           Text="{Binding TopbarTitle}" 
           FontSize="20" 
           FontAttributes="Bold" 
           TextColor="#062035" 
           VerticalTextAlignment="Center"/>
            <Label Grid.Column="2" 
           FontSize="14" 
           TextColor="#4a7a92"
           VerticalTextAlignment="Center">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Good day, "/>
                        <Span Text="{Binding GreetingName}" FontAttributes="Bold" TextColor="#006064"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </Grid>

        <!-- Tab Navigation -->
        <!-- NEW -->
        <FlexLayout Grid.Row="1" Wrap="Wrap" JustifyContent="Center" AlignItems="Center" BackgroundColor="White" Padding="12,10">
            <Button Text="Overview" Command="{Binding ShowPanelCommand}" CommandParameter="overview"
                FontSize="12" CornerRadius="18" Padding="14,8" BackgroundColor="#e8f4f8" TextColor="#4a7a92" Margin="4,4,4,4">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsOverviewPanelVisible}" Value="True">
                            <Setter Property="BackgroundColor" Value="#006064"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="My Profile" Command="{Binding ShowPanelCommand}" CommandParameter="profile"
                FontSize="12" CornerRadius="18" Padding="14,8" BackgroundColor="#e8f4f8" TextColor="#4a7a92" Margin="4,4,4,4">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsProfilePanelVisible}" Value="True">
                            <Setter Property="BackgroundColor" Value="#006064"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Bookings" Command="{Binding ShowPanelCommand}" CommandParameter="bookings"
                FontSize="12" CornerRadius="18" Padding="14,8" BackgroundColor="#e8f4f8" TextColor="#4a7a92" Margin="4,4,4,4">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsBookingsPanelVisible}" Value="True">
                            <Setter Property="BackgroundColor" Value="#006064"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Availability" Command="{Binding ShowPanelCommand}" CommandParameter="availability"
                FontSize="12" CornerRadius="18" Padding="14,8" BackgroundColor="#e8f4f8" TextColor="#4a7a92" Margin="4,4,4,4">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsAvailabilityPanelVisible}" Value="True">
                            <Setter Property="BackgroundColor" Value="#006064"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Reviews" Command="{Binding ShowPanelCommand}" CommandParameter="reviews"
                FontSize="12" CornerRadius="18" Padding="14,8" BackgroundColor="#e8f4f8" TextColor="#4a7a92" Margin="4,4,4,4">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsReviewsPanelVisible}" Value="True">
                            <Setter Property="BackgroundColor" Value="#006064"/>
                            <Setter Property="TextColor" Value="White"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Log Out" Command="{Binding LogoutCommand}"
                FontSize="12" CornerRadius="18" Padding="14,8" BackgroundColor="#fdecea" TextColor="#e53935"/>
        </FlexLayout>

        <!-- Main Content -->
        <ScrollView Grid.Row="2" Padding="16">
            <VerticalStackLayout Spacing="20">

                <!-- Overview Panel -->
                <VerticalStackLayout IsVisible="{Binding IsOverviewPanelVisible}" Spacing="16">
                    <!-- Stats Grid -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <Border Grid.Row="0" Grid.Column="0" StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="{Binding TotalBookings}" FontSize="24" FontAttributes="Bold" TextColor="#062035"/>
                                    <Label Text="Total Bookings" FontSize="12" TextColor="#4a7a92"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="{Binding PendingBookings}" FontSize="24" FontAttributes="Bold" TextColor="#062035"/>
                                    <Label Text="Pending" FontSize="12" TextColor="#4a7a92"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="{Binding CompletedBookings}" FontSize="24" FontAttributes="Bold" TextColor="#062035"/>
                                    <Label Text="Completed" FontSize="12" TextColor="#4a7a92"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="{Binding AverageRating}" FontSize="24" FontAttributes="Bold" TextColor="#062035"/>
                                    <Label Text="Avg. Rating" FontSize="12" TextColor="#4a7a92"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Recent Bookings -->
                    <Border StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Recent Bookings" FontSize="16" FontAttributes="Bold" TextColor="#062035"/>
                            <CollectionView ItemsSource="{Binding RecentBookings}" SelectionMode="Single">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Margin="0,4" Padding="12">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <VerticalStackLayout Grid.Column="0">
                                                    <Label Text="{Binding CaregiverName}" FontSize="14" FontAttributes="Bold" TextColor="#062035"/>
                                                    <Label Text="{Binding ServiceName}" FontSize="12" TextColor="#4a7a92"/>
                                                    <Label Text="{Binding DateTimeDisplay}" FontSize="11" TextColor="#4a7a92"/>
                                                </VerticalStackLayout>
                                                <Border Grid.Column="1"
                                                        StrokeShape="RoundRectangle(20)"
                                                        Padding="10,4"
                                                        BackgroundColor="{Binding StatusColor}"
                                                        VerticalOptions="Center">
                                                    <Label Text="{Binding Status}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="{Binding StatusTextColor}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Label Text="No bookings yet. Complete your profile to get started!" 
                                   FontSize="13" 
                                   TextColor="#4a7a92"
                                   IsVisible="{Binding HasNoBookings}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Profile Panel -->
                <VerticalStackLayout IsVisible="{Binding IsProfilePanelVisible}" Spacing="16">
                    <!-- Profile Hero -->
                    <Border StrokeShape="RoundRectangle(14)" Padding="20" BackgroundColor="#0a2a4a">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                            <Label Grid.Column="0" 
                                   Text="👤" 
                                   FontSize="48"
                                   VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding ProfileName}" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                                <Label Text="Caregiver · SwiftCare" FontSize="13" TextColor="#b0d4e3"/>
                                <Border StrokeShape="RoundRectangle(20)" Padding="6,4" BackgroundColor="#0d5f6f">
                                    <Label Text="● Available for bookings" FontSize="12" TextColor="#80deea" HorizontalTextAlignment="Center"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Personal Information -->
                    <Border StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Personal Information" FontSize="16" FontAttributes="Bold" TextColor="#062035"/>
                            
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Full Name" FontSize="12" FontAttributes="Bold" TextColor="#1a4a62"/>
                                <Entry x:Name="EntryProfileName" Placeholder="Your full name" Text="{Binding ProfileModel.FullName}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Phone Number" FontSize="12" FontAttributes="Bold" TextColor="#1a4a62"/>
                                <Entry x:Name="EntryProfilePhone" Placeholder="09XX XXX XXXX" Keyboard="Telephone" Text="{Binding ProfileModel.ContactNo}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="City / Location" FontSize="12" FontAttributes="Bold" TextColor="#1a4a62"/>
                                <Entry x:Name="EntryProfileCity" Placeholder="e.g. Biñan, Laguna" Text="{Binding ProfileModel.Address}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Hourly Rate (₱)" FontSize="12" FontAttributes="Bold" TextColor="#1a4a62"/>
                                <Entry x:Name="EntryProfileRate" Placeholder="e.g. 150" Keyboard="Numeric" Text="{Binding ProfileModel.HourlyRate}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label FontSize="12" FontAttributes="Bold" TextColor="#1a4a62">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Bio / About Me "/>
                                            <Span Text="{Binding BioCharCount}" TextColor="#4a7a92" FontAttributes="None"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Editor x:Name="EditorBio" 
                                        Placeholder="Tell families about yourself..." 
                                        HeightRequest="90"
                                        Text="{Binding ProfileModel.Bio}"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Services Offered (loaded from the database, not hardcoded) -->
                    <Border StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Services I Offer" FontSize="16" FontAttributes="Bold" TextColor="#062035"/>
                            <CollectionView ItemsSource="{Binding AvailableServices}">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="14"/>
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <HorizontalStackLayout Spacing="8">
                                            <CheckBox IsChecked="{Binding IsSelected}" Color="#00838f" VerticalOptions="Center"/>
                                            <Label Text="{Binding ServiceName}" FontSize="12" VerticalOptions="Center" LineBreakMode="TailTruncation"/>
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <Button Text="Save Profile" 
                            Command="{Binding SaveProfileCommand}"
                            BackgroundColor="#006064"
                            TextColor="White"
                            CornerRadius="10"/>
                </VerticalStackLayout>

                <!-- Bookings Panel -->
                <VerticalStackLayout IsVisible="{Binding IsBookingsPanelVisible}" Spacing="12">
                    <Border StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Bookings" FontSize="16" FontAttributes="Bold" TextColor="#062035"/>
                            <CollectionView ItemsSource="{Binding AllBookings}" SelectionMode="Single">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Margin="0,4" Padding="12">
                                            <VerticalStackLayout Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <VerticalStackLayout Grid.Column="0">
                                                        <Label Text="{Binding CaregiverName}" FontSize="14" FontAttributes="Bold" TextColor="#062035"/>
                                                        <Label Text="{Binding ServiceName}" FontSize="12" TextColor="#4a7a92"/>
                                                        <Label Text="{Binding DateTimeDisplay}" FontSize="11" TextColor="#4a7a92"/>
                                                        <Label Text="{Binding TotalPrice, StringFormat='₱{0:0.00}'}" FontSize="13" FontAttributes="Bold" TextColor="#006064"/>
                                                    </VerticalStackLayout>
                                                    <Border Grid.Column="1"
                                                            StrokeShape="RoundRectangle(20)"
                                                            Padding="10,4"
                                                            BackgroundColor="{Binding StatusColor}"
                                                            VerticalOptions="Center">
                                                        <Label Text="{Binding Status}"
                                                               FontSize="11"
                                                               FontAttributes="Bold"
                                                               TextColor="{Binding StatusTextColor}"/>
                                                    </Border>
                                                </Grid>

                                                <!-- Accept/Decline: only offered while the booking is still Pending -->
                                                <HorizontalStackLayout Spacing="8" IsVisible="{Binding CanAccept}">
                                                    <Button Text="✓ Accept"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.AcceptBookingCommand}"
                                                            CommandParameter="{Binding BookingID}"
                                                            BackgroundColor="#26c6da"
                                                            TextColor="White"
                                                            FontSize="12"
                                                            CornerRadius="8"
                                                            Padding="14,8"/>
                                                    <Button Text="✕ Decline"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.DeclineBookingCommand}"
                                                            CommandParameter="{Binding BookingID}"
                                                            BackgroundColor="#e53935"
                                                            TextColor="White"
                                                            FontSize="12"
                                                            CornerRadius="8"
                                                            Padding="14,8"/>
                                                </HorizontalStackLayout>

                                                <!-- Complete: only offered once the caregiver has already accepted (Confirmed) -->
                                                <Button Text="✔ Mark as Completed"
                                                        IsVisible="{Binding CanComplete}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.CompleteBookingCommand}"
                                                        CommandParameter="{Binding BookingID}"
                                                        BackgroundColor="#2e7d32"
                                                        TextColor="White"
                                                        FontSize="12"
                                                        CornerRadius="8"
                                                        Padding="14,8"/>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Label Text="No bookings found." 
                                   FontSize="13" 
                                   TextColor="#4a7a92"
                                   IsVisible="{Binding HasNoAllBookings}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Availability Panel -->
                <VerticalStackLayout IsVisible="{Binding IsAvailabilityPanelVisible}" Spacing="12">
                    <!-- Weekly Availability -->
                    <Border StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Weekly Availability" FontSize="16" FontAttributes="Bold" TextColor="#062035"/>

                            <!-- Index order matches Common.DayOfWeekHelper (0=Mon ... 6=Sun) — same order as the web app -->
                            <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="6">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="Mon" FontSize="11" FontAttributes="Bold" TextColor="#1a4a62" HorizontalTextAlignment="Center"/>
                                    <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Padding="6">
                                        <CheckBox IsChecked="{Binding IsMondaySelected}" Color="#00838f" HorizontalOptions="Center"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Tue" FontSize="11" FontAttributes="Bold" TextColor="#1a4a62" HorizontalTextAlignment="Center"/>
                                    <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Padding="6">
                                        <CheckBox IsChecked="{Binding IsTuesdaySelected}" Color="#00838f" HorizontalOptions="Center"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Spacing="4">
                                    <Label Text="Wed" FontSize="11" FontAttributes="Bold" TextColor="#1a4a62" HorizontalTextAlignment="Center"/>
                                    <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Padding="6">
                                        <CheckBox IsChecked="{Binding IsWednesdaySelected}" Color="#00838f" HorizontalOptions="Center"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="3" Spacing="4">
                                    <Label Text="Thu" FontSize="11" FontAttributes="Bold" TextColor="#1a4a62" HorizontalTextAlignment="Center"/>
                                    <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Padding="6">
                                        <CheckBox IsChecked="{Binding IsThursdaySelected}" Color="#00838f" HorizontalOptions="Center"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="4" Spacing="4">
                                    <Label Text="Fri" FontSize="11" FontAttributes="Bold" TextColor="#1a4a62" HorizontalTextAlignment="Center"/>
                                    <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Padding="6">
                                        <CheckBox IsChecked="{Binding IsFridaySelected}" Color="#00838f" HorizontalOptions="Center"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="5" Spacing="4">
                                    <Label Text="Sat" FontSize="11" FontAttributes="Bold" TextColor="#1a4a62" HorizontalTextAlignment="Center"/>
                                    <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Padding="6">
                                        <CheckBox IsChecked="{Binding IsSaturdaySelected}" Color="#00838f" HorizontalOptions="Center"/>
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="6" Spacing="4">
                                    <Label Text="Sun" FontSize="11" FontAttributes="Bold" TextColor="#1a4a62" HorizontalTextAlignment="Center"/>
                                    <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Padding="6">
                                        <CheckBox IsChecked="{Binding IsSundaySelected}" Color="#00838f" HorizontalOptions="Center"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout Spacing="12">
                                <Label Text="Available From" FontSize="12" FontAttributes="Bold" TextColor="#1a4a62"/>
                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                    <TimePicker Grid.Column="0" Time="{Binding DayStartTime}"/>
                                    <Label Grid.Column="1" Text="to" VerticalOptions="Center" FontSize="12"/>
                                    <TimePicker Grid.Column="2" Time="{Binding DayEndTime}"/>
                                </Grid>
                            </VerticalStackLayout>

                            <Button Text="💾 Save Availability"
                                    Command="{Binding SaveAvailabilityCommand}"
                                    BackgroundColor="#006064"
                                    TextColor="White"
                                    CornerRadius="10"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Reviews Panel -->
                <VerticalStackLayout IsVisible="{Binding IsReviewsPanelVisible}" Spacing="12">
                    <Border StrokeShape="RoundRectangle(14)" BackgroundColor="#0a2a4a" Padding="16">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label Text="{Binding AverageRating}" FontSize="48" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Text="⭐⭐⭐⭐⭐" FontSize="18" TextColor="#ffd54f" HorizontalTextAlignment="Center"/>
                                <Label Text="{Binding ReviewCount}" FontSize="12" TextColor="#b0d4e3" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Border StrokeShape="RoundRectangle(14)" StrokeThickness="1" Stroke="#e8f4f8" Padding="16">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Customer Reviews" FontSize="16" FontAttributes="Bold" TextColor="#062035"/>
                            <CollectionView ItemsSource="{Binding Reviews}" SelectionMode="Single">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border StrokeShape="RoundRectangle(10)" StrokeThickness="1" Stroke="#e8f4f8" Margin="0,4" Padding="12">
                                            <VerticalStackLayout Spacing="8">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <VerticalStackLayout Grid.Column="0">
                                                        <Label Text="{Binding ClientName}" FontSize="14" FontAttributes="Bold" TextColor="#062035"/>
                                                        <Label Text="{Binding ReviewDate}" FontSize="11" TextColor="#4a7a92"/>
                                                    </VerticalStackLayout>
                                                    <Label Grid.Column="1" Text="{Binding Stars}" FontSize="14" TextColor="#ffd54f" VerticalOptions="Center"/>
                                                </Grid>
                                                <Label Text="{Binding ReviewText}" FontSize="13" TextColor="#1a4a62"/>
                                                <Label Text="{Binding ServiceName}" FontSize="11" TextColor="#006064" FontAttributes="Bold"/>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Label Text="No reviews yet. Complete bookings to earn reviews!" 
                                   FontSize="13" 
                                   TextColor="#4a7a92"
                                   IsVisible="{Binding HasNoReviews}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>